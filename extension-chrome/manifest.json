{
  "manifest_version": 3,
  "name": "VLESS Switch",
  "version": "1.0.0",
  "description": "Переключение сайтов через локальный VLESS(Reality)-прокси (Xray-core), по образцу Browsec.",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "key": ""
}